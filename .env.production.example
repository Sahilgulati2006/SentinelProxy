APP_NAME=SentinelProxy
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

PROVIDER_NAME=openai_compatible
DEFAULT_MODEL=

OLLAMA_BASE_URL=

OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

REDIS_URL=
REDIS_TTL_SECONDS=1800

DATABASE_URL=

BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_MONTHLY_TOKEN_LIMIT=100000

API_KEY_PEPPER=replace_with_long_random_secret
SENTINEL_ADMIN_KEY=replace_with_long_random_admin_key

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

REQUEST_TIMEOUT_SECONDS=120
MAX_REQUEST_CHARS=20000

CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com